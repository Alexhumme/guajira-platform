# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=guajira_platform
DB_PORT=3306

# Server
PORT=5000
NODE_ENV=development

# Session Secret (generate a secure random string)
SESSION_SECRET=your-super-secret-session-key-here

# Admin bootstrap (creates first admin via /api/auth/bootstrap)
ADMIN_BOOTSTRAP_USER=admin
ADMIN_BOOTSTRAP_PASSWORD=change_me

# File Upload
MAX_FILE_SIZE=10MB
UPLOAD_PATH=./uploads

# Email Configuration (optional)
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=

# Third-party APIs (if needed)
GOOGLE_MAPS_API_KEY=
CLOUDINARY_URL=
